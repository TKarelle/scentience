
# Public site URL (no trailing slash)
VITE_SITE_ORIGIN=https://madeleine.uk

# Analytics (optional — enable one or both)
# VITE_PLAUSIBLE_DOMAIN=madeleine.uk
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Social
VITE_INSTAGRAM_URL=https://www.instagram.com/madeleine

# Stripe publishable key (optional — hosted Checkout redirect only needs server secret)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# API base URL — leave empty in dev (Vite proxies /api to port 4242)
# VITE_API_URL=https://madeleine.uk

# Server
PORT=4242
CLIENT_URL=http://localhost:5173

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Confirmation emails (https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=MADELEINE <orders@madeleine.uk>
ORDERS_EMAIL_TO=Info@madeleine.uk
CONTACT_EMAIL_TO=Info@madeleine.uk
